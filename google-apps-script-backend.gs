const ADMIN_EMAIL="CHANGE_ME@example.com";
function doPost(e){const p=JSON.parse(e.postData.contents),d=p.data||{};const ss=SpreadsheetApp.getActive(),sh=ss.getSheetByName("CervicePro")||ss.insertSheet("CervicePro");if(sh.getLastRow()===0)sh.appendRow(["Timestamp","Event","Work Order","Equipment ID","Machine","Fault","Condition","Repair","Root Cause","Cost"]);sh.appendRow([new Date(),p.event,d.id,d.machine?.id,d.machine?.name,d.fault,d.condition,d.repair,d.rootCause,d.totalCost||0]);const subject=`CervicePro ${p.event==="completed"?"Completed Repair":"Fault Report"} — ${d.machine?.label||d.machine?.id}`;const html=`<h2>${subject}</h2><p><b>Machine:</b> ${d.machine?.name||""}</p><p><b>Fault:</b> ${d.fault||""}</p><p><b>Condition:</b> ${d.condition||""}</p><p><b>Repair:</b> ${d.repair||""}</p><p><b>Root cause:</b> ${d.rootCause||""}</p>`;MailApp.sendEmail({to:ADMIN_EMAIL,subject,htmlBody:html});return ContentService.createTextOutput("ok");}